{
  "design_identity": {
    "persona": "E1 - The Anti-AI Designer",
    "core_principles": [
      "Fusion over Imitation: Brown Aesthetic x Gen-Z Chaos x Interactive Gaming",
      "Emotion First: Cozy vibes meet sudden bursts of energy (Among Us/Confetti)",
      "Content is King: Every section is an inside joke",
      "Imperfection: Use tilted elements, handwritten fonts, and scattered layouts to feel human"
