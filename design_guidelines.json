    "hall_of_shame": [
      "No generic 'Happy Birthday' banners",
      "No standard Bootstrap grids",
      "No boring default shadows - use colored, layered shadows",
      "No 'Inter' for headings"
    ]
  },
  "typography": {
    "headings": {
      "family": "Syne",
      "weights": ["700", "800"],
      "usage": "Main titles, dramatic statements",
      "fallback": "sans-serif"
    },
    "body": {
      "family": "DM Sans",
      "weights": ["400", "500", "700"],
      "usage": "Paragraphs, UI elements",
      "fallback": "sans-serif"
    },
    "handwritten": {
      "family": "Gloria Hallelujah",
      "weights": ["400"],
      "usage": "Polaroid captions, annotations, stickers",
      "fallback": "cursive"
    }
  },
